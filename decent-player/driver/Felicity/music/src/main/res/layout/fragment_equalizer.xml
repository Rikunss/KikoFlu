<?xml version="1.0" encoding="utf-8"?>
<app.simple.felicity.decorations.padding.PaddingAwareLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/padding_15"
        android:orientation="horizontal">

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_36"
            android:text="@string/equalizer"
            android:paddingVertical="@dimen/padding_10"
            app:appFontStyle="black"
            app:textColorStyle="primary" />

        <app.simple.felicity.decorations.toggles.FelicityButtonGroup
            android:id="@+id/panel_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <app.simple.felicity.decorations.theme.ThemeDivider
        android:layout_width="match_parent"
        android:layout_height="1px" />

    <app.simple.felicity.decorations.views.FelicityViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/equalizer_screen"
            layout="@layout/screen_equalizer" />

        <include
            android:id="@+id/speaker_screen"
            layout="@layout/screen_speakers" />

        <include
            android:id="@+id/reverb_screen"
            layout="@layout/screen_reverb" />

    </app.simple.felicity.decorations.views.FelicityViewFlipper>


</app.simple.felicity.decorations.padding.PaddingAwareLinearLayout>
