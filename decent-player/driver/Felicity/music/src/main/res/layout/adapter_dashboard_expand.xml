<?xml version="1.0" encoding="utf-8"?>
<app.simple.felicity.decorations.ripple.DynamicRippleLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/padding_5"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/padding_10">

    <app.simple.felicity.decorations.theme.ThemeIcon
        android:id="@+id/icon"
        android:layout_width="@dimen/icon_size_30"
        android:layout_height="@dimen/icon_size_30"
        android:src="@drawable/ic_unfold"
        app:tintType="accent" />

    <app.simple.felicity.decorations.typeface.TypeFaceTextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_8"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/more"
        android:textSize="@dimen/text_size_14"
        app:appFontStyle="bold"
        app:textColorStyle="secondary" />

</app.simple.felicity.decorations.ripple.DynamicRippleLinearLayout>

