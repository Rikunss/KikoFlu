<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_gravity="bottom"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/padding_15"
    android:layout_height="wrap_content">

    <app.simple.felicity.decorations.corners.DynamicCornerLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:padding="@dimen/padding_15"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="0dp"
                android:padding="@dimen/padding_15"
                android:layout_height="wrap_content"
                android:text="@string/sync_adjust"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.highlight.HighlightTextView
                android:id="@+id/minus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_minus_ms"
                android:paddingVertical="@dimen/padding_5"
                android:paddingHorizontal="@dimen/padding_10"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/padding_5"
                app:appFontStyle="medium"
                app:buttonTintType="regular"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.highlight.HighlightTextView
                android:id="@+id/plus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_plus_ms"
                android:paddingVertical="@dimen/padding_5"
                android:paddingHorizontal="@dimen/padding_10"
                android:layout_gravity="center_vertical"
                app:appFontStyle="medium"
                app:buttonTintType="regular"
                app:textColorStyle="secondary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="0dp"
                android:padding="@dimen/padding_15"
                android:layout_height="wrap_content"
                android:text="@string/alignment"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.toggles.FelicityButtonGroup
                android:id="@+id/lyrics_alignment_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="wrap_content"
                android:padding="@dimen/padding_15"
                android:layout_height="wrap_content"
                android:text="@string/text_size"
                android:layout_gravity="center_vertical"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.seekbars.FelicitySeekbar
                android:id="@+id/text_size_seekbar"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_10"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/padding_1"
                app:felicityAnimateInitial="true"
                app:felicityLabelBackgroundEnabled="true"
                app:felicityLabelsEnabled="true"
                app:felicityMax="24"
                app:felicityMin="12"
                app:felicityProgress="16"
                app:felicityThumbRadius="@dimen/padding_10"
                app:felicityThumbRingWidth="@dimen/padding_10"
                app:felicityTrackHeight="@dimen/padding_10" />

        </LinearLayout>

        <app.simple.felicity.decorations.theme.ThemeDivider
            android:layout_width="match_parent"
            android:layout_marginVertical="@dimen/padding_10"
            android:layout_height="1px" />

        <app.simple.felicity.decorations.ripple.DynamicRippleTextView
            android:id="@+id/delete"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/padding_15"
            android:text="@string/delete_lyrics"
            android:textSize="@dimen/text_size_14"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

    </app.simple.felicity.decorations.corners.DynamicCornerLinearLayout>

</FrameLayout>