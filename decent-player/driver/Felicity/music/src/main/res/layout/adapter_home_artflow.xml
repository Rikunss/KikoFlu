<app.simple.felicity.decorations.square.SquareFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <app.simple.felicity.decorations.pager.FelicitySlider
        android:id="@+id/felicitySlider"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:showIndicator="true"
        app:slideIntervalMs="5000"
        app:slideSwiftness="0.2" />

    <app.simple.felicity.decorations.highlight.HighlightTextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginHorizontal="@dimen/padding_15"
        android:layout_marginBottom="@dimen/padding_25"
        android:textSize="@dimen/text_size_18"
        android:padding="@dimen/padding_10"
        android:drawablePadding="@dimen/padding_20"
        app:appFontStyle="bold"
        app:drawableEndCompat="@drawable/ic_for_arrow"
        app:drawableTint="@color/white"
        app:drawableTintStyle="custom"
        app:highlightCustomColor="#50000000"
        app:textColorStyle="white" />

</app.simple.felicity.decorations.square.SquareFrameLayout>