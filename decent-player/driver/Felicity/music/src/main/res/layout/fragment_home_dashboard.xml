<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:animateLayoutChanges="true"
        android:layout_height="match_parent"
        app:layout_behavior=".decorations.behaviors.OverScrollBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/padding_15">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:maxLines="1"
                    android:layout_gravity="center_vertical"
                    android:singleLine="true"
                    android:text="@string/app_name"
                    android:textSize="@dimen/text_size_36"
                    app:appFontStyle="black"
                    app:textColorStyle="primary" />

                <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                    android:id="@+id/search"
                    android:layout_width="@dimen/button_size"
                    android:layout_height="@dimen/button_size"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_search" />

                <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                    android:id="@+id/settings"
                    android:layout_width="@dimen/button_size"
                    android:layout_height="@dimen/button_size"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_settings" />

            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/strip"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/padding_10"
                android:paddingHorizontal="@dimen/padding_15"
                android:scrollbars="none"
                android:fadingEdge="horizontal"
                android:animateLayoutChanges="true"
                android:requiresFadingEdge="horizontal"
                android:fadingEdgeLength="@dimen/padding_20"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:animateLayoutChanges="true"
                    android:orientation="horizontal">

                    <app.simple.felicity.decorations.highlight.HighlightTextView
                        android:id="@+id/currently_playing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/padding_5"
                        android:paddingHorizontal="@dimen/padding_10"
                        android:maxWidth="250dp"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:drawableStart="@drawable/ic_play_16dp"
                        android:drawablePadding="@dimen/padding_5"
                        android:textSize="@dimen/text_size_14"
                        app:appFontStyle="bold"
                        app:drawableTintStyle="accent"
                        app:highlightMode="both"
                        app:textColorStyle="secondary" />

                </LinearLayout>

            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/empty_library_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_20"
                android:layout_marginHorizontal="@dimen/padding_20"
                android:layout_marginTop="@dimen/padding_20"
                android:alpha="0.8"
                android:visibility="gone">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_music_found"
                    android:textSize="@dimen/text_size_16"
                    android:gravity="center"
                    app:appFontStyle="medium"
                    app:textColorStyle="secondary" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/recommended_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/padding_20"
                    android:paddingBottom="@dimen/padding_8"
                    android:paddingHorizontal="@dimen/padding_20">

                    <app.simple.felicity.decorations.typeface.TypeFaceTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="center_vertical"
                        android:text="@string/recommended"
                        android:textSize="@dimen/text_size_22"
                        app:appFontStyle="bold"
                        app:textColorStyle="primary" />

                    <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                        android:id="@+id/refresh_recommended"
                        android:layout_width="@dimen/button_size"
                        android:layout_height="@dimen/button_size"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_refresh" />

                </LinearLayout>

                <app.simple.felicity.decorations.views.CornerRadiusRectRecyclerView
                    android:id="@+id/recommended_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutAnimation="@anim/spanned_animation_controller"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:layout_marginHorizontal="@dimen/padding_20"
                    android:clipToPadding="false" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/recently_played_section"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:paddingBottom="@dimen/padding_8"
                    android:paddingHorizontal="@dimen/padding_20"
                    android:paddingTop="@dimen/padding_20"
                    android:text="@string/recently_played"
                    android:textSize="@dimen/text_size_22"
                    app:appFontStyle="bold"
                    app:textColorStyle="primary" />

                <app.simple.felicity.decorations.overscroll.CustomHorizontalRecyclerView
                    android:id="@+id/recently_played_list"
                    android:clipToPadding="false"
                    android:layoutAnimation="@anim/list_pop_in_animation_controller"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:paddingHorizontal="@dimen/padding_20"
                    app:navigationPaddingRequired="false"
                    app:statusPaddingRequired="false" />

            </LinearLayout>

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:paddingBottom="@dimen/padding_8"
                android:paddingHorizontal="@dimen/padding_20"
                android:paddingTop="@dimen/padding_20"
                android:text="@string/browse"
                android:textSize="@dimen/text_size_22"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/panels_recycler_view"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:paddingHorizontal="@dimen/padding_15"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <LinearLayout
                android:id="@+id/recently_added_section"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:paddingBottom="@dimen/padding_8"
                    android:paddingHorizontal="@dimen/padding_20"
                    android:paddingTop="@dimen/padding_20"
                    android:text="@string/recently_added"
                    android:textSize="@dimen/text_size_22"
                    app:appFontStyle="bold"
                    app:textColorStyle="primary" />

                <app.simple.felicity.decorations.overscroll.CustomHorizontalRecyclerView
                    android:id="@+id/recently_added_list"
                    android:clipToPadding="false"
                    android:layoutAnimation="@anim/list_pop_in_animation_controller"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:paddingHorizontal="@dimen/padding_20"
                    app:navigationPaddingRequired="false"
                    app:statusPaddingRequired="false" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/favorites_section"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:paddingBottom="@dimen/padding_8"
                    android:paddingHorizontal="@dimen/padding_20"
                    android:paddingTop="@dimen/padding_20"
                    android:text="@string/favorites"
                    android:textSize="@dimen/text_size_22"
                    app:appFontStyle="bold"
                    app:textColorStyle="primary" />

                <app.simple.felicity.decorations.overscroll.CustomHorizontalRecyclerView
                    android:id="@+id/favorites_list"
                    android:clipToPadding="false"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:paddingHorizontal="@dimen/padding_20"

                    app:navigationPaddingRequired="false"
                    app:statusPaddingRequired="false" />

            </LinearLayout>


        </LinearLayout>

    </app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
